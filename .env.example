# Copy to .env and fill in real values. Never commit .env.

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast2
GCS_BUCKET=your-gcp-project-id-transjakarta-raw
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# BigQuery datasets
BQ_DATASET_RAW=raw_gtfs
BQ_DATASET_OPEN_DATA=raw_jakarta_open_data
BQ_DATASET_STAGING=staging
BQ_DATASET_MARTS_CORE=marts_core
BQ_DATASET_MARTS_PRESENTATION=marts_presentation

# GTFS source — set exactly ONE of the two below.
#   GTFS_FEED_URL    : public HTTP(S) URL to the .zip
#   GTFS_LOCAL_ZIP   : path to a local .zip (use when the source is gated
#                      behind a form, e.g. Transjakarta's PPID portal)
GTFS_FEED_URL=
GTFS_LOCAL_ZIP=./data/raw/transjakarta-gtfs.zip
